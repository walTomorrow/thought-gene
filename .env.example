# Reference values only — copy to wrangler.toml and/or .dev.vars for local use.
# Do not put real secrets in this file.

# Cloudflare account ID (also set as account_id in wrangler.toml)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Workers AI model identifier (must match an active model in the Workers AI catalog)
# Current project default: @cf/meta/llama-3.1-8b-instruct-fast
# Deprecated: @cf/meta/llama-3.1-8b-instruct (removed 2026-05-30)
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
