# Copy to .dev.vars in the project root for local Wrangler overrides.
# Wrangler loads .dev.vars automatically during `pnpm dev`.
# Overrides wrangler.toml [vars] when present.

# Current project default: @cf/meta/llama-3.1-8b-instruct-fast
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct-fast

# Workers AI defaults max_tokens to 256 unless overridden:
# CLOUDFLARE_AI_MAX_TOKENS=2048
# CLOUDFLARE_AI_MERGE_MAX_TOKENS=4096